generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model ToolGroup {
  id          String       @id @default(cuid())
  name        String
  notes       String?
  tools       Tool[]
  attachments Attachment[]

  @@map("Family")
}

model Tool {
  id             String       @id @default(cuid())
  projectName    String
  dueDate        DateTime?
  status         ToolStatus   @default(Management)
  toolGroupId    String?      @map("familyId")
  toolGroup      ToolGroup?   @relation(fields: [toolGroupId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  projectType    ProjectType  @default(NewTool)
  archived       Boolean      @default(false)
  archivedAt     DateTime?
  machineTarget  String?
  parts          Part[]
  sections       Section[]
  events         CalendarEvent[]
  issues         Issue[]
}

model Section {
  id     String @id @default(cuid())
  name   String
  toolId String
  tool   Tool   @relation(fields: [toolId], references: [id], onDelete: Cascade)
  parts  Part[]
}

model Part {
  id                String            @id @default(cuid())
  toolId            String
  tool              Tool              @relation(fields: [toolId], references: [id], onDelete: Cascade)
  sectionId         String?
  section           Section?          @relation(fields: [sectionId], references: [id])
  name              String
  type              PartType          @default(standard)
  quantity          Int               @default(1)
  /// @deprecated Not derived from operations. Kept for schema compatibility; do not use in active logic or UI.
  status            PartStatus        @default(NotOrdered)
  supplier          String?
  notes             String?
  drawingRef        String?
  requiresLaser     Boolean           @default(false)
  isStandard        Boolean           @default(false)
  material          String?
  thickness         String?
  size              String?
  createdAt         DateTime          @default(now())
  conversionStatus  ConversionStatus  @default(New)
  materialType      MaterialType?
  dimX              Float?
  dimY              Float?
  dimZ              Float?
  revModel          Int               @default(1)
  revProgram        Int               @default(1)
  revProgramNote    String?
  operations        Operation[]
  outsourceJobs     OutsourceJob[]
  attachments       Attachment[]
  orders            Order[]
  orderItems        OrderItem[]
  issues            Issue[]
}

model Attachment {
  id          String         @id @default(cuid())
  name        String
  type        AttachmentType
  filePath    String?
  url         String?
  partId      String?
  part        Part?          @relation(fields: [partId], references: [id], onDelete: SetNull)
  toolGroupId String?        @map("familyId")
  toolGroup   ToolGroup?     @relation(fields: [toolGroupId], references: [id], onDelete: SetNull)
  operationId String?
  operation   Operation?     @relation(fields: [operationId], references: [id], onDelete: SetNull)
  createdAt   DateTime       @default(now())
}

model Operation {
  id                String          @id @default(cuid())
  partId            String
  part              Part            @relation(fields: [partId], references: [id], onDelete: Cascade)
  name              String
  order             Int
  type              OperationType   @default(internal)
  status            OperationStatus @default(NotStarted)
  dependsOnPrevious Boolean         @default(true)
  machine           String?
  supplier          String?
  estimatedTime     Float?
  actualTime        Float?
  createdAt         DateTime        @default(now())
  changedBy         String?
  statusChangedAt   DateTime?
  programRevision   Int?
  programRevNote    String?
  toolList          String?
  orderId           String?
  linkedOrder       Order?          @relation(fields: [orderId], references: [id], onDelete: SetNull)
  outsourceJobId    String?
  linkedJob         OutsourceJob?   @relation(fields: [outsourceJobId], references: [id], onDelete: SetNull)
  attachments       Attachment[]
}

model Order {
  id               String       @id @default(cuid())
  supplier         String
  supplierId       String?
  linkedSupplier   Supplier?    @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  partId           String?
  part             Part?        @relation(fields: [partId], references: [id], onDelete: SetNull)
  status           OrderStatus  @default(Draft)
  createdAt        DateTime     @default(now())
  eta              DateTime?
  notes            String?
  poNumber         String?
  supplierQuoteRef String?
  operations       Operation[]
  items            OrderItem[]
}

model OrderItem {
  id      String  @id @default(cuid())
  orderId String
  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  partId  String
  part    Part    @relation(fields: [partId], references: [id], onDelete: Cascade)
  qty     Int     @default(1)
  notes   String?
}

model OutsourceJob {
  id             String          @id @default(cuid())
  partId         String
  part           Part            @relation(fields: [partId], references: [id], onDelete: Cascade)
  company        String
  supplierId     String?
  linkedSupplier Supplier?       @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  status         OutsourceStatus @default(Pending)
  sentDate       DateTime?
  eta            DateTime?
  notes          String?
  externalJobRef String?
  operations     Operation[]
}

model ActivityLog {
  id         String   @id @default(cuid())
  entityType String
  entityId   String
  entityName String
  action     String
  detail     String?
  toolId     String?
  partId     String?
  createdAt  DateTime @default(now())
}

model CalendarEvent {
  id          String   @id @default(cuid())
  toolId      String?
  tool        Tool?    @relation(fields: [toolId], references: [id], onDelete: SetNull)
  title       String
  date        DateTime
  description String?
  createdAt   DateTime @default(now())
}

model Issue {
  id          String        @id @default(cuid())
  toolId      String
  tool        Tool          @relation(fields: [toolId], references: [id], onDelete: Cascade)
  partId      String?
  part        Part?         @relation(fields: [partId], references: [id], onDelete: SetNull)
  title       String
  description String?
  status      IssueStatus   @default(Open)
  priority    IssuePriority @default(Medium)
  openedAt    DateTime      @default(now())
  closedAt    DateTime?
  createdAt   DateTime      @default(now())
}

model ProcessCard {
  id        String   @id @default(cuid())
  toolId    String
  partId    String
  printedAt DateTime @default(now())
  printedBy String?
}

model TodoItem {
  id                String      @id @default(cuid())
  column            TodoColumn
  text              String
  subtext           String?
  done              Boolean     @default(false)
  doneAt            DateTime?
  order             Int         @default(0)
  weekStart         DateTime
  linkedPartId      String?
  linkedOperationId String?
  createdAt         DateTime    @default(now())
}

model Supplier {
  id                   String           @id @default(cuid())
  name                 String
  email                String
  notes                String?
  emailSubjectTemplate String?
  emailBodyTemplate    String?
  createdAt            DateTime         @default(now())
  category             SupplierCategory @default(Material)
  orders               Order[]
  outsourceJobs        OutsourceJob[]
}

// ── Enums ──────────────────────────────────────────────────────────────────

enum ToolStatus {
  Management
  CAD
  CAM
  Manufacturing
  Toolmaking
  Done
  Cancelled
}

enum ProjectType {
  NewTool
  Conversion
  Modification
  RnD
  Custom
}

enum PartType {
  standard
  custom
  outsource
}

enum PartStatus {
  NotOrdered
  Ordered
  InProgress
  Ready
  Installed
}

enum ConversionStatus {
  New
  Reuse
  Rework
}

enum MaterialType {
  ToolingPlate
  RawStock
}

enum OperationType {
  procurement
  internal
  outsource
  inspection
  assembly
}

enum OperationStatus {
  NotStarted
  Ready
  InProgress
  Sent
  Done
  Blocked
  NotOrdered
  Ordered
  Received
  Pending
}

enum OrderStatus {
  Draft
  Sent
  Received
  Cancelled
}

enum OutsourceStatus {
  Pending
  Sent
  InProgress
  Done
  Cancelled
}

enum AttachmentType {
  DXF
  PDF
  STEP
  NC
  IMAGE
  OTHER
}

enum IssueStatus {
  Open
  InProgress
  Closed
}

enum IssuePriority {
  Low
  Medium
  High
  Critical
}

enum SupplierCategory {
  Material
  Gundrilling
  Laser
  WaterJet
  Other
}

enum TodoColumn {
  MyTasks
  Hurco
  Danusys
}

model Note {
  id        String   @id @default(cuid())
  title     String
  content   String
  category  String?
  tags      String?
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ReferenceCategory {
  id        String           @id @default(cuid())
  name      String
  icon      String?
  order     Int              @default(0)
  entries   ReferenceEntry[]
  createdAt DateTime         @default(now())
}

model ReferenceEntry {
  id         String            @id @default(cuid())
  categoryId String
  category   ReferenceCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  label      String
  value      String
  unit       String?
  notes      String?
  order      Int               @default(0)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
}

model FusionRef {
  id        String   @id @default(cuid())
  section   String
  date      String
  path      String
  notes     String?
  createdAt DateTime @default(now())
}
